# =========================================================================
# AMTCE CONFIGURATION TEMPLATE (.env)
# Copy this file to .env and fill in your developer keys.
# DO NOT commit your actual .env file to public source control.
# =========================================================================

# === 1. GOOGLE OAUTH CONFIGURATION (YOUTUBE) ===
# Create these at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === 2. META OAUTH CONFIGURATION (INSTAGRAM/FACEBOOK) ===
# Create these at https://developers.facebook.com/
META_CLIENT_ID=
META_CLIENT_SECRET=

# === 3. TIKTOK OAUTH CONFIGURATION (TIKTOK DIRECT POSTING) ===
# Create these at https://developers.tiktok.com/
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# === 3.5. GITHUB OAUTH CONFIGURATION ===
# Create these at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# === 4. GENERAL APP SETTINGS ===
# The base URL of your web application (used for OAuth Redirect URIs)
OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:5000
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=False

# === 5. EXISTING TELEGRAM BACKUP CREDENTIALS ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CREDENTIALS_ENCRYPTION_KEY=
